{
  "name": "@sentio/cli",
  "version": "3.0.0-development",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentioxyz/sentio-sdk.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "sentio": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "!**/*.test.*",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "pnpm tsc --noEmit && pnpm bundle",
    "postbuild": "pnpm install",
    "bundle": "esbuild --platform=node --format=esm --bundle src/index.ts --outfile=dist/index.js --sourcemap --inject:src/cjs-shim.ts --external:@sentio/sdk",
    "cli": "tsx src/index.ts",
    "compile": "tsc",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "types": "module",
  "dependencies": {
    "@aptos-labs/ts-sdk": "~7.1.0",
    "@iota/iota-sdk": "~1.14.0",
    "@mysten/sui": "~2.17.0",
    "@sentio/api": "~1.0.4",
    "@sentio/chain": "~3.4.22",
    "@sentio/graph-cli": "^0.97.0",
    "@types/node": "^24.0.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "dotenv": "^17.0.0",
    "ethers": "npm:@sentio/ethers@6.13.1-patch.6",
    "express": "^5.0.0",
    "form-data": "^4.0.0",
    "fs-extra": "^11.2.0",
    "jszip": "^3.10.1",
    "latest-version": "^9.0.0",
    "node-fetch": "^3.3.2",
    "open": "^11.0.0",
    "package-manager-manager": "^0.2.0",
    "solc": "^0.8.25",
    "tsdown": "^0.22.3",
    "tsx": "^4.15.2",
    "yaml": "^2.3.4"
  },
  "peerDependencies": {
    "@sentio/sdk": "workspace:^"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4"
  },
  "engines": {
    "node": ">=24.11.0"
  }
}
