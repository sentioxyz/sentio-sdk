{
  "name": "@sentio/action",
  "version": "3.0.0-development",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentioxyz/sentio-sdk.git",
    "directory": "packages/action"
  },
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src",
    "!**/*.test.*",
    "!**/tests"
  ],
  "scripts": {
    "build": "pnpm gen && pnpm compile",
    "build:all": "pnpm --filter=$(node -p \"require('./package.json').name\")... build",
    "build:bundle": "pnpm gen && pnpm bundle && pnpm bundle:dts",
    "compile": "tsc && cp src/tsup.config.ts lib",
    "gen": "echo",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@sentio/protos": "workspace:*",
    "@sentio/runtime": "workspace:^",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "prettier": "^3.2.4",
    "typedoc": "^0.28.0"
  },
  "engines": {
    "node": ">=22"
  }
}
